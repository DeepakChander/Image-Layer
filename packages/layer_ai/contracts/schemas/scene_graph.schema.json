{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Layer AI Scene Graph",
  "type": "object",
  "required": ["job_id", "root_id", "nodes"],
  "properties": {
    "job_id": { "type": "string" },
    "root_id": { "type": "string" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "name", "children", "z_index"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "name": { "type": "string" },
          "children": {
            "type": "array",
            "items": { "type": "string" }
          },
          "z_index": { "type": "integer" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
